# DashScope 百炼 API Key，用于 ASR 和意图分类
DASHSCOPE_API_KEY=your_dashscope_api_key
# 高德 Web 服务 API Key，用于地址标准化复核
AMAP_KEY=your_amap_web_service_key

# ─── AICCS 通信智能引擎（外呼）配置 ───
# 阿里云 AccessKey，用于调用 LlmSmartCall / CreateAiCallTask 等外呼 API
# 获取路径：阿里云控制台 → AccessKey 管理
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
# 大模型应用编码，在「智能联络中心 → 通信智能引擎 → 大模型应用管理」创建后获取
AICCS_APP_CODE=your_aiccs_app_code
# 已申请的主叫号码，在「智能联络中心 → 小模型通信 → 号码管理」购买/绑定
CALLER_NUMBER=your_caller_number
# 网关授权码，自定义设置，AICCS 请求你的网关时通过 Authorization header 携带
# 需与「大模型网关配置」中填写的授权码一致
GATEWAY_AUTH_TOKEN=your_gateway_auth_token
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_REQUESTS=true

# 可按实际接入模型覆盖，默认值已经能跑通当前代码
ASR_MODEL=qwen3-asr-flash-realtime
LLM_MODEL=qwen3.5-flash
# TTS 模型。当前推荐 cosyvoice-v3-flash，适合 demo 做机器人播报
TTS_MODEL=cosyvoice-v3-flash
# TTS 音色。可替换为电话客服/电话助手类音色，例如 longyingtao_v3、longyingxun_v3
TTS_VOICE=longanyang
# 合成音频格式。macOS 下 mp3 配合 afplay 最省事
TTS_FORMAT=mp3
# 合成音频采样率。24k 适合本地播报；后续电话场景可评估 8k/16k
TTS_SAMPLE_RATE=24000
# 单句 TTS 最长等待时间，避免网络异常时卡住主流程
TTS_TIMEOUT_SECONDS=20.0

# 本地 VAD 参数。环境噪声大时，可适当提高能量阈值
VAD_ENERGY_THRESHOLD=700
# 用户说完后，连续静音多久判定为结束
VAD_END_SILENCE_SECONDS=1.0
# 多久没检测到人声就当作超时
VAD_NO_RESPONSE_SECONDS=8.0
# 单轮录音最大时长，防止异常情况下持续录音
MAX_RECORD_SECONDS=30.0

# 是否打印 ASR / 意图 / 高德中间结果，联调时建议开启
DEBUG=true
