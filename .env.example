# =========================
# Go 应用基础配置
# =========================
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=info

# 内部接口鉴权
INTERNAL_API_TOKEN=replace_me

# 阿里云回调鉴权
AICCS_CALLBACK_TOKEN=replace_me

# AICCS 请求 Go 网关时携带的 Bearer token。
# 阿里云「大模型网关配置」里的「授权码(API-key)」字段需填写完整 Authorization 值：
# Bearer <GATEWAY_AUTH_TOKEN>
GATEWAY_AUTH_TOKEN=replace_me

# =========================
# 阿里云 AICCS 外呼配置（Go 主链路）
# =========================
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
AICCS_APP_CODE=your_aiccs_app_code
CALLER_NUMBER=your_caller_number
AICCS_REGION_ID=cn-hangzhou
AICCS_ENDPOINT=aiccs.aliyuncs.com
AICCS_SESSION_TIMEOUT=1200

# =========================
# PostgreSQL 配置
# =========================
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=beilang
PG_PASSWORD=replace_me
PG_DATABASE=beilang_callbot
PG_SSLMODE=disable

# =========================
# Go 文本处理依赖
# =========================
# DashScope 百炼 API Key，用于 Go 意图识别和地址确认话术
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TIMEOUT_SECONDS=3
LLM_MODEL=qwen3.5-flash

# 高德 Web 服务 API Key，用于 Go 地址标准化复核
AMAP_KEY=your_amap_web_service_key
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_CITY=广州
AMAP_TIMEOUT_SECONDS=3
