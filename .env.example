# =========================
# Go 应用基础配置
# =========================
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=info

# 内部接口鉴权
INTERNAL_API_TOKEN=replace_me

# 阿里云回调鉴权
AICCS_CALLBACK_TOKEN=replace_me

# =========================
# 阿里云 AICCS 外呼配置（Go 主链路）
# =========================
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
AICCS_APP_CODE=your_aiccs_app_code
CALLER_NUMBER=your_caller_number
AICCS_REGION_ID=cn-hangzhou
AICCS_ENDPOINT=aiccs.aliyuncs.com
AICCS_SESSION_TIMEOUT=1200

# =========================
# PostgreSQL 配置
# =========================
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=beilang
PG_PASSWORD=replace_me
PG_DATABASE=beilang_callbot
PG_SSLMODE=disable

# =========================
# Python AI / 本地 Demo 保留配置（可选）
# =========================
# DashScope 百炼 API Key，用于本地 Demo 或后续 AI 文本服务
DASHSCOPE_API_KEY=your_dashscope_api_key
# 高德 Web 服务 API Key，用于地址标准化复核
AMAP_KEY=your_amap_web_service_key

ASR_MODEL=qwen3-asr-flash-realtime
LLM_MODEL=qwen3.5-flash
TTS_MODEL=cosyvoice-v3-flash
TTS_VOICE=longanyang
TTS_FORMAT=mp3
TTS_SAMPLE_RATE=24000
TTS_TIMEOUT_SECONDS=20.0
VAD_ENERGY_THRESHOLD=700
VAD_END_SILENCE_SECONDS=1.0
VAD_NO_RESPONSE_SECONDS=8.0
MAX_RECORD_SECONDS=30.0
DEBUG=true
